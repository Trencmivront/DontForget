Tables;
TASKS -> task_id, task_title, description, status_id, priority, due_date, list_order, project_id, created_at, updated_at, completed_at.
TASK_STATUS -> status_id, status_name
ICON_COLOR -> icon_color_id, red, green, blue
PROJECTS -> project_id, project_title, list_order, icon_color_id
TAGS -> tag_id, tag_name, icon_color_id
RECURRING_TASKS -> task_id, day_of_week, max_occourrences
REMINDERS -> task_id, remind_at, cstm_message
INBOX -> inbox_id, message, created_at

Relationships;
TASKS - TASK_STATUS = M:1
TASKS - PROJECTS = M:1
TASKS - TAGS = M:N
TASKS - RECURRING_TASKS = 1:1
TASKS - REMINDERS = 1:1
PROJECTS - ICON_COLOR = M:1
TAGS - ICON_COLOR = M:1

Constraints;
- All foreign key constraints
- Task title must be unique
- Project title must be unique
- priority is in (1, 2, 3)
- due_date is not older than current date
- project_id can be null
- status_name is in ('ACTIVE', 'COMPLETED', 'PAST')
- red, green and blue values are between (0, 256)
- tag_name is unique